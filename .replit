modules = ["python-3.11", "system", "nix", "nodejs-20", "postgresql-16"]
[deployment]
deploymentTarget = "static"
build = ["bash", "-c", "cd marketing-site && npm install && npm run build"]
publicDir = "marketing-site/dist"

[nix]
channel = "stable-25_05"
packages = ["cairo", "cargo", "ffmpeg-full", "freetype", "ghostscript", "glibcLocales", "gobject-introspection", "gtk3", "libiconv", "libxcrypt", "libyaml", "pkg-config", "qhull", "rustc", "tcl", "tk", "xsimd"]

[agent]
integrations = ["python_openai_ai_integrations:1.0.0", "streamlit_database:1.0.0", "resend:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Marketing site"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run app.py --server.port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Marketing site"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd marketing-site && npm ci && ASTRO_TELEMETRY_DISABLED=1 npm run build && npx --yes serve dist -l tcp://0.0.0.0:8000 --no-clipboard"
waitForPort = 8000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8001
externalPort = 3000

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
