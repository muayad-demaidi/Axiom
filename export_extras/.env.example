# AXIOM (DataVision Pro) — Environment Variables Template
# Copy to .env and fill in your real values. NEVER commit .env to git.

# ─────────────────────────────────────────────────────────────
# REQUIRED — the app will not start without these
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string (e.g. from Replit, Neon, Supabase, Render)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/axiom

# OpenAI API key — used by AI assistant, insights, cleaning report
# Get one from: https://platform.openai.com/api-keys
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...

# Optional: custom OpenAI base URL (leave unset to use OpenAI directly)
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Resend transactional email service (welcome emails, support contact form)
# Get one from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ─────────────────────────────────────────────────────────────
# OPTIONAL — SEO agent (only needed if running seo_agent/)
# ─────────────────────────────────────────────────────────────

# Perplexity API for trending-topic research
PERPLEXITY_API_KEY=pplx-...

# Plausible Analytics for organic-traffic feedback
PLAUSIBLE_API_KEY=

# Path to a Google Search Console CSV export (optional traffic feedback)
GSC_CSV_IMPORT_PATH=

# Daily/weekly USD budget cap for the SEO agent's OpenAI spend
SEO_AGENT_BUDGET_USD=2

# Which OpenAI model the SEO agent uses
SEO_AGENT_MODEL=gpt-4o-mini

# Public URL of the deployed marketing site (used for canonical URLs, sitemaps)
SEO_AGENT_PUBLIC_APP_URL=https://your-domain.com

# Auto-publish vs. require human approval (false = require approval)
SEO_AGENT_AUTO_PUBLISH=false

# Set to true to disable the background build worker (queue still fills up)
SEO_AGENT_DISABLE_BUILD_WORKER=false

# Set to true to allow only the build step (no content generation)
SEO_AGENT_ALLOW_BUILD_ONLY=false

# Custom build command override (defaults to the marketing-site build script)
SEO_AGENT_BUILD_CMD=

# Webhook URL fired after a successful publish (e.g. Replit deploy hook)
SEO_AGENT_DEPLOY_HOOK_URL=
SEO_AGENT_DEPLOY_HOOK_TOKEN=

# ─────────────────────────────────────────────────────────────
# REPLIT-SPECIFIC — auto-set by Replit, do NOT set manually
# ─────────────────────────────────────────────────────────────
# REPL_IDENTITY=
# REPLIT_CONNECTORS_HOSTNAME=
# REPLIT_DEV_DOMAIN=
# REPLIT_DOMAINS=
# WEB_REPL_RENEWAL=
