---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../utils/site";
import FAQ from "../components/FAQ.astro";

const description =
  "AXIOM pricing — three tiers, all currently free during testing. 60-day Tier 3 trial included with every account, no credit card required.";

const faq = [
  { q: "Is AXIOM really free right now?", a: "Yes — all tiers are free during our public testing period. The only difference between tiers is feature access; there is no payment step today." },
  { q: "What happens after the 60-day trial?", a: "Your account is downgraded to a free tier you choose; the platform asks you to contact us to keep Tier 3 access." },
  { q: "Will pricing change later?", a: "When we move out of public testing we'll publish paid pricing here with at least 30 days' notice. Existing trial accounts will get a clear migration path." },
  { q: "Do you offer team accounts?", a: "Team accounts are on the roadmap. Today every user has their own login and dataset library." },
];

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
};
---
<BaseLayout title="Pricing & Tiers" description={description} jsonLd={faqLd}>
  <section class="hero" style="padding-top:5rem; padding-bottom:2rem;">
    <div class="container">
      <span class="eyebrow">Pricing</span>
      <h1>Three tiers. <span class="gradient-text">All free during testing.</span></h1>
      <p class="lead">Every new account starts on a 60-day Tier 3 trial — full features, no credit card. After the trial you choose any tier you like and keep going.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        <div class="card">
          <h3>Tier 1 — Starter</h3>
          <p class="mono small muted">For light, occasional analysis.</p>
          <ul>
            <li>50 MB max file size</li>
            <li>10,000 rows max</li>
            <li>Auto-cleaning pipeline</li>
            <li>Descriptive statistics</li>
            <li>Visualisations</li>
            <li>—</li>
            <li>—</li>
          </ul>
        </div>
        <div class="card" style="border-color: var(--border-strong);">
          <h3>Tier 2 — Pro</h3>
          <p class="mono small muted">For working analysts.</p>
          <ul>
            <li>200 MB max file size</li>
            <li>500,000 rows max</li>
            <li>Everything in Tier 1</li>
            <li>Predictive models</li>
            <li>ML &amp; K-Means clustering</li>
            <li>—</li>
            <li>—</li>
          </ul>
        </div>
        <div class="card" style="border-color: var(--teal); box-shadow: var(--shadow-glow);">
          <h3>Tier 3 — Studio</h3>
          <p class="mono small muted">Default during your 60-day trial.</p>
          <ul>
            <li>200 MB max file size</li>
            <li>1,000,000 rows max</li>
            <li>Everything in Tier 2</li>
            <li>AI chat assistant</li>
            <li>Export reports (PDF/HTML)</li>
            <li>Cleaning recipes</li>
            <li>Time-period comparison</li>
          </ul>
          <a class="btn btn-primary" style="margin-top:1rem;" href={SITE.appUrl}>Start Tier 3 trial →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <FAQ items={faq} />
    </div>
  </section>
</BaseLayout>
