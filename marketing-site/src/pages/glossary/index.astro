---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { SITE } from "../../utils/site";

const entries = (await getCollection("glossary")).sort((a, b) =>
  a.data.term.localeCompare(b.data.term)
);

const description =
  "DataVision Pro Glossary — clear, sourced definitions of core data analytics terms: data cleaning, outlier detection, K-Means, data drift, ETL vs ELT, descriptive statistics, predictive analytics, and more.";

const breadcrumbsLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: SITE.url },
    { "@type": "ListItem", position: 2, name: "Glossary", item: SITE.url + "/glossary" },
  ],
};

const itemListLd = {
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  name: "DataVision Pro Data Analytics Glossary",
  hasDefinedTerm: entries.map((g) => ({
    "@type": "DefinedTerm",
    name: g.data.term,
    description: g.data.shortDef,
    url: SITE.url + "/glossary/" + g.slug,
  })),
};
---
<BaseLayout title="Glossary" description={description} jsonLd={[breadcrumbsLd, itemListLd]}>
  <section class="hero" style="padding-top:5rem; padding-bottom:1.5rem;">
    <div class="container">
      <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Glossary" }]} />
      <span class="eyebrow">Glossary</span>
      <h1>Plain-English data analytics, with sources.</h1>
      <p class="lead">
        {entries.length} definitions of core data analytics concepts. Each one starts with a 40-second answer, lists real cited statistics, and ends with the questions analysts actually ask.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        {entries.map((g) => (
          <a class="term-card" href={`/glossary/${g.slug}`}>
            <h3>{g.data.term}</h3>
            <p>{g.data.shortDef}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
