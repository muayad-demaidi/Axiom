---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import FAQ from "../../components/FAQ.astro";
import RelatedReading from "../../components/RelatedReading.astro";
import { SITE } from "../../utils/site";

export async function getStaticPaths() {
  const entries = await getCollection("glossary");
  return entries.map((e) => ({ params: { slug: e.slug }, props: { entry: e } }));
}

const { entry } = Astro.props;
const data = entry.data;
const { Content } = await entry.render();

const allEntries = await getCollection("glossary");
const related = data.related
  .map((slug) => allEntries.find((e) => e.slug === slug))
  .filter(Boolean);

const url = SITE.url + "/glossary/" + entry.slug;

const definedTermLd = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  name: data.term,
  description: data.shortDef,
  url,
  inDefinedTermSet: SITE.url + "/glossary",
};

const articleLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: data.question,
  description: data.description,
  datePublished: data.updated,
  dateModified: data.updated,
  author: { "@type": "Organization", name: SITE.organization.name, url: SITE.url },
  publisher: {
    "@type": "Organization",
    name: SITE.organization.name,
    logo: { "@type": "ImageObject", url: SITE.url + "/logo.png" },
  },
  mainEntityOfPage: url,
};

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: data.faq.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const breadcrumbsLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: SITE.url },
    { "@type": "ListItem", position: 2, name: "Glossary", item: SITE.url + "/glossary" },
    { "@type": "ListItem", position: 3, name: data.term, item: url },
  ],
};
---
<BaseLayout
  title={data.question}
  description={data.description}
  type="article"
  jsonLd={[definedTermLd, articleLd, faqLd, breadcrumbsLd, ...(data.jsonLd ?? [])]}
>
  <section class="section" style="padding-top:3.5rem;">
    <div class="container" style="max-width: 820px;">
      <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Glossary", href: "/glossary" }, { label: data.term }]} />
      <span class="eyebrow">Glossary</span>
      <h1>{data.question}</h1>
      <div class="updated">Updated {data.updated}</div>

      <p style="font-size: 1.1rem; color: var(--text);"><strong>{data.answer}</strong></p>

      {data.stats.map((s) => (
        <div class="stat">
          <div class="value">{s.value}</div>
          <div>{s.label}</div>
          <cite><a href={s.source.url} rel="nofollow noopener" target="_blank">{s.source.label}</a></cite>
        </div>
      ))}

      <Content />

      <FAQ items={data.faq} />

      <h2>Related terms</h2>
      <div class="grid grid-2">
        {related.map((r) => (
          <a class="term-card" href={`/glossary/${r!.slug}`}>
            <h3>{r!.data.term}</h3>
            <p>{r!.data.shortDef}</p>
          </a>
        ))}
      </div>

      <RelatedReading guides={data.relatedGuides} compare={data.relatedCompare} />

      <div class="cta-strip">
        <h2>Try this in DataVision Pro</h2>
        <p>Upload a CSV and see the concept applied to your own data — free for 60 days.</p>
        <a class="btn btn-primary" href={SITE.appUrl}>Launch the app →</a>
      </div>
    </div>
  </section>
</BaseLayout>
