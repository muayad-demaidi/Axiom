---
type Crumb = { label: string; href?: string };
const { items } = Astro.props as { items: Crumb[] };
---
<nav class="breadcrumbs" aria-label="Breadcrumb">
  {items.map((c, i) => (
    <>
      {i > 0 && <span> / </span>}
      {c.href ? <a href={c.href}>{c.label}</a> : <span>{c.label}</span>}
    </>
  ))}
</nav>
